    "dayjs": "^1.11.21",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "github-api": "^3.4.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^2.5.1",
    "memoizee": "^0.4.17",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.21.0",
    "pg-promise": "^11.15.0",
    "sanitize-filename": "^1.6.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
